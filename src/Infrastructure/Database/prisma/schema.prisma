// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

//----------Database structure is in this file--------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  TENANT
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model User {
  //(id:- column name, String:- stored as text/uuid @id :- primary key, default:- autogenerate uuid)

  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  fullName     String
  phone        String? @unique

  role      UserRole
  avatarUrl String?

  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(true)
  isSuspended     Boolean @default(false)

  suspensionReason String?
  suspendedAt      DateTime?
  suspendedBy      String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastActive  DateTime?
  lastLoginAt DateTime?

  owner_profile  OwnerProfile?
  tenant_profile TenantProfile?
  admin_profile  AdminProfile?

  tokens     VerificationToken[]
  properties Property[]
  wishlist   Wishlist[]

  ownedAgreements      Agreement[] @relation("AgreementOwner")
  tenantAgreements     Agreement[] @relation("AgreementTenant")
  terminatedAgreements Agreement[] @relation("AgreementTerminatedBy")

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

model OwnerProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?
  occupation String?

  documentType       String?
  documentUrl        String?
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?
  verifiedAt         DateTime?          @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VerificationStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model TenantProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?
  occupation String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminRole        String
  twoFactorEnabled Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model VerificationToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenType  TokenType
  tokenValue String
  isUsed     Boolean   @default(false)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, tokenType])
  @@index([tokenValue])
}

model Property {
  id           String @id @default(uuid())
  ownerId      String
  owner        User   @relation(fields: [ownerId], references: [id])
  title        String
  description  String
  propertyType String
  areaSqrt     Int?

  locationDistrict String
  locationCity     String
  locationPincode  String
  fullAddress      String

  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  nearbyLandmarks String?

  monthlyRent         Decimal @db.Decimal(10, 2)
  depositAmount       Decimal @db.Decimal(10, 2)
  maintenanceCharges  Decimal @default(0)
  maintenanceIncluded Boolean @default(true)

  photos         String[]
  mainPhotoIndex Int      @default(0)
  videoTourUrl   String?

  status        PropertyVerificationStatus @default(PENDING_APPROVAL)
  rejectionReason String?
  isFeatured    Boolean                    @default(false)
  availableFrom DateTime?

  viewsCount       Int @default(0)
  inquiryCount     Int @default(0)
  wishlistCount    Int @default(0)
  virtualTourCount Int @default(0)

  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  details          PropertyDetails?
  serviceProviders ServiceProvider[]
  wishlist         Wishlist[]
  agreements       Agreement[]

  @@index([ownerId])
  @@index([status])
  @@index([locationDistrict, locationCity])
  @@index([propertyType])
}

enum PropertyVerificationStatus {
  PENDING_APPROVAL
  ACTIVE
  RENTED
  UNLISTED
  REJECTED
}

model PropertyDetails {
  id String @id @default(uuid())

  propertyId String   @unique
  property   Property @relation(fields: [propertyId], references: [id])

  bhk              Int?
  bathrooms        Int?
  floorNumber      String?
  totalFloors      Int?
  propertyAge      String?
  facingDirection  String?
  furnishingStatus String?

  landType      String?
  isCornerPlot  Boolean?
  roadWidthFeet Int?

  shoptype   String?
  hasParking Boolean?

  preferredTenantType Json?
  petsAllowed         Boolean  @default(false)
  smokingAllowed      Boolean  @default(false)
  maximumOccupants    Int?
  amenities           String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceProvider {
  id                   String    @id @default(uuid())
  property_id          String
  property             Property  @relation(fields: [property_id], references: [id], onDelete: Cascade)
  provider_type        String    @db.VarChar(50)
  provider_name        String    @db.VarChar(255)
  phone                String    @db.VarChar(20)
  typical_charges_min  Decimal?  @db.Decimal(8, 2)
  typical_charges_max  Decimal?  @db.Decimal(8, 2)
  rating               Decimal?  @default(0) @db.Decimal(3, 2)
  total_jobs_completed Int?      @default(0)
  is_active            Boolean?  @default(true)
  created_at           DateTime? @default(now())
  updated_at           DateTime? @default(now())

  @@index([property_id])
  @@index([provider_type])
}

// ─── Agreement enums ──────────────────────────────────────────────────────────

enum AgreementStatus {
  DRAFT
  PENDING_TENANT_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
}

enum DepositRefundStatus {
  PENDING
  PARTIAL
  FULL
  DISPUTED
}

// ─── Agreement model ──────────────────────────────────────────────────────────

model Agreement {
  id              String  @id @default(uuid())
  agreementNumber String  @unique @db.VarChar(50)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  ownerId String
  owner   User   @relation("AgreementOwner", fields: [ownerId], references: [id])

  tenantId String
  tenant   User   @relation("AgreementTenant", fields: [tenantId], references: [id])

  // Terms
  startDate           DateTime
  endDate             DateTime
  lockInPeriodMonths  Int
  noticePeriodMonths  Int

  // Financial
  monthlyRent              Decimal @db.Decimal(10, 2)
  depositAmount            Decimal @db.Decimal(10, 2)
  maintenanceCharges       Decimal @default(0) @db.Decimal(8, 2)
  maintenanceIncluded      Boolean @default(true)
  lateFeePerDay            Decimal @default(100) @db.Decimal(8, 2)
  lateFeeGracePeriodDays   Int     @default(3)
  rentEscalationPercentage Decimal @default(0) @db.Decimal(5, 2)

  // Content
  termsAndConditions Json?
  customClauses      String?
  tenantRemarks      String?

  // Signatures
  ownerSignatureUrl  String?
  ownerSignedAt      DateTime?
  tenantSignatureUrl String?
  tenantSignedAt     DateTime?
  agreementPdfUrl    String?

  // Status
  status            AgreementStatus @default(DRAFT)
  terminationReason String?
  terminatedAt      DateTime?
  terminatedById    String?
  terminatedBy      User?           @relation("AgreementTerminatedBy", fields: [terminatedById], references: [id])

  // Deposit tracking
  depositPaid          Boolean             @default(false)
  depositPaidAt        DateTime?
  depositRefundStatus  DepositRefundStatus?
  depositRefundAmount  Decimal?            @db.Decimal(10, 2)
  depositRefundDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agreementNumber])
  @@index([propertyId])
  @@index([ownerId])
  @@index([tenantId])
  @@index([status])
  @@index([startDate, endDate])
}
