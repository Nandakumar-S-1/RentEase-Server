// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

//----------Database structure is in this file--------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  TENANT
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model User {
  //(id:- column name, String:- stored as text/uuid @id :- primary key, default:- autogenerate uuid)

  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  fullName     String
  phone        String? @unique

  role      UserRole
  avatarUrl String?

  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(true)
  isSuspended     Boolean @default(false)

  suspensionReason String?
  suspendedAt      DateTime?
  suspendedBy      String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastActive  DateTime?
  lastLoginAt DateTime?

  owner_profile  OwnerProfile?
  tenant_profile TenantProfile?
  admin_profile  AdminProfile?

  tokens     VerificationToken[]
  properties Property[]

  @@index([email])
  @@index([phone])
  @@index([role])
}

model OwnerProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?
  occupation String?

  documentType       String?
  documentUrl        String?
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?
  verifiedAt         DateTime?          @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VerificationStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model TenantProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?
  occupation String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminRole        String
  twoFactorEnabled Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model VerificationToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenType  TokenType
  tokenValue String
  isUsed     Boolean   @default(false)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, tokenType])
  @@index([tokenValue])
}

model Property {
  id           String @id @default(uuid())
  ownerId      String
  owner        User   @relation(fields: [ownerId], references: [id])
  title        String
  description  String
  propertyType String
  areaSqrt     Int?

  locationDistrict String
  locationCity     String
  locationPincode  String
  fullAddress      String

  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  nearbyLandmarks String?

  monthlyRent         Decimal @db.Decimal(10, 2)
  depositAmount       Decimal @db.Decimal(10, 2)
  maintenanceCharges  Decimal @default(0)
  maintenanceIncluded Boolean @default(true)

  photos         String[]
  mainPhotoIndex Int      @default(0)
  videoTourUrl   String?

  status        PropertyVerificationStatus @default(PENDING_APPROVAL)
  isFeatured    Boolean                    @default(false)
  availableFrom DateTime?

  viewsCount       Int @default(0)
  inquiryCount     Int @default(0)
  wishlistCount    Int @default(0)
  virtualTourCount Int @default(0)

  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  details PropertyDetails?

  @@index([ownerId])
  @@index([status])
  @@index([locationDistrict, locationCity])
  @@index([propertyType])
}

enum PropertyVerificationStatus {
  PENDING_APPROVAL
  ACTIVE
  RENTED
  UNLISTED
  REJECTED
}

model PropertyDetails {
  id String @id @default(uuid())

  propertyId String   @unique
  property   Property @relation(fields: [propertyId], references: [id])

  bhk              Int?
  bathrooms        Int?
  floorNumber      String?
  totalFloors      Int?
  propertyAge      String?
  facingDirection  String?
  furnishingStatus String?

  landType      String?
  isCornerPlot  Boolean?
  roadWidthFeet Int?

  shoptype   String?
  hasParking Boolean?

  preferredTenantType Json?
  petsAllowed         Boolean @default(false)
  smokingAllowed      Boolean @default(false)
  maximumOccupants    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
